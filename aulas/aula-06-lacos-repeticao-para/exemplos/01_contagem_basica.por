programa {
    funcao inicio() {
        // Exemplo 1: contar de 1 até N com o laço para

        inteiro n

        escreva("Digite o número limite: ")
        leia(n)

        escreval("Contando de 1 até ", n, ":")

        para(inteiro i = 1; i <= n; i++) {
            escreval(i)
        }

        escreval("Fim da contagem!")
    }
}
